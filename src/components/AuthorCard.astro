---
const {
  showLinks = true,
  showHandle = false,
} = Astro.props;

const authorLinkClass =
  "inline-flex h-[18px] w-[18px] items-center justify-center text-muted transition-colors duration-150 hover:text-ink";
const iconClass = "h-4 w-4";
---

<div
  class="grid justify-items-start gap-[0.35rem] text-left max-mobile:mx-auto max-mobile:w-fit max-mobile:min-w-60 max-mobile:self-center"
>
  <div class="flex items-center gap-4">
    <img
      src="/mu-icon.png"
      alt=""
      class="h-[100px] w-[100px] rounded-xl border border-border bg-paper"
    />
    <div class="text-left">
      <div class="font-semibold">Masato</div>
      {showHandle && <div class="author-handle">@01mu_dev</div>}
      {showLinks && (
        <div class="mt-[0.35rem] flex justify-start gap-[0.65rem]">
          <a
            href="https://x.com/01mu_dev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X"
            class={authorLinkClass}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
              <path
                fill="currentColor"
                d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"
              />
            </svg>
          </a>
          <a
            href="https://github.com/01-mu"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class={authorLinkClass}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class={iconClass}>
              <path
                fill="currentColor"
                d="M12 2.2a9.8 9.8 0 0 0-3.1 19.1c.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.4-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.5 1.1 3.1.8.1-.6.4-1.1.7-1.3-2.2-.3-4.5-1.1-4.5-5a3.9 3.9 0 0 1 1-2.7c-.1-.2-.4-1.2.1-2.5 0 0 .9-.3 2.8 1a9.6 9.6 0 0 1 5.1 0c1.9-1.3 2.8-1 2.8-1 .5 1.3.2 2.3.1 2.5a3.9 3.9 0 0 1 1 2.7c0 4-2.3 4.7-4.5 5 .4.3.8 1 .8 2.1v3.1c0 .3.2.6.7.5A9.8 9.8 0 0 0 12 2.2Z"
              />
            </svg>
          </a>
          <a href="/rss.xml" aria-label="RSS" class={authorLinkClass}>
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5">
              <path
                fill="currentColor"
                d="M6.2 17.8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM2.2 10.4v3.1c4.3 0 7.8 3.5 7.8 7.8h3.1c0-6-4.9-10.9-10.9-10.9Zm0-6.7v3.1c8 0 14.5 6.5 14.5 14.5h3.1c0-9.7-7.9-17.6-17.6-17.6Z"
              />
            </svg>
          </a>
        </div>
      )}
    </div>
  </div>
</div>
