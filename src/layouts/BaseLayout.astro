---
import "../styles/global.css";

const { title, description, mainClass = "main--page" } = Astro.props;
const siteTitle = "Masato log";
const siteTagline = "think from nothing.";
const pageTitle = title ? `${title} · ${siteTitle}` : siteTitle;
const pageDescription = description ?? siteTagline;
const pageUrl = Astro.url.href;
const ogType = title ? "article" : "website";
const bodyClasses = [
  "m-0 flex min-h-screen flex-col",
  "[&_a]:border-b [&_a]:border-transparent [&_a]:text-inherit [&_a]:no-underline [&_a]:transition-[border-color] [&_a]:duration-150 [&_a:hover]:border-border [&_a:focus-visible]:outline-2 [&_a:focus-visible]:outline-offset-3 [&_a:focus-visible]:outline-accent",
  "[&_h1]:my-10 [&_h1]:mb-4 [&_h1]:text-[1.9rem] [&_h1]:leading-[1.25] [&_h1]:font-[560]",
  "[&_h2]:my-10 [&_h2]:mb-4 [&_h2]:text-[1.4rem] [&_h2]:leading-[1.25] [&_h2]:font-[560]",
  "[&_h3]:my-10 [&_h3]:mb-4 [&_h3]:text-[1.1rem] [&_h3]:leading-[1.25] [&_h3]:font-[560]",
  "[&_p]:my-5",
  "[&_code]:font-mono [&_code]:text-[0.92em] [&_pre]:overflow-x-auto [&_pre]:rounded-md [&_pre]:bg-code-bg [&_pre]:px-[1.2rem] [&_pre]:py-4 [&_pre]:font-mono [&_pre]:text-[0.92em]",
  "[&_blockquote]:my-6 [&_blockquote]:border-l-2 [&_blockquote]:border-border [&_blockquote]:px-5 [&_blockquote]:py-[0.2rem] [&_blockquote]:text-muted",
];
const mainClasses = [
  mainClass,
  "mx-auto min-h-[70vh] flex-1 bg-paper",
  mainClass === "main--post" &&
    "max-w-none bg-transparent px-0 pt-6 pb-[3.2rem] max-mobile:pt-10 max-mobile:pb-[2.8rem]",
  mainClass === "main--home" &&
    "max-w-none bg-transparent px-0 pt-6 pb-[3.2rem] max-tablet:m-0 max-mobile:pt-[1.2rem] max-mobile:pb-[2.8rem]",
  mainClass === "main--page" &&
    "max-w-none px-0 pt-6 pb-[3.2rem] max-mobile:pt-[1.2rem] max-mobile:pb-[2.8rem]",
  !["main--post", "main--home", "main--page"].includes(mainClass) &&
    "max-w-[76ch] px-6 pt-14 pb-[3.2rem] max-mobile:px-5 max-mobile:pt-10 max-mobile:pb-[2.8rem]",
];
---

<!DOCTYPE html>
<html
  lang="en"
  class="bg-main font-serif text-ink leading-[1.75] [text-rendering:optimizeLegibility]"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="canonical" href={pageUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Masato log"
      href="/rss.xml"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={bodyClasses}>
    <header
      class="flex w-full items-baseline justify-between gap-4 px-8 pt-[1.2rem] max-mobile:flex-col max-mobile:items-start max-mobile:gap-3 max-mobile:px-6 max-mobile:pt-5"
    >
      <div class="flex flex-col gap-[0.06rem] pb-4 text-left">
        <a
          href="/"
          class="text-[1.8rem] font-semibold tracking-[0.01em]"
          aria-label="Masato log"
        >
          {siteTitle}
        </a>
        <div class="text-[0.95rem] text-muted">{siteTagline}</div>
      </div>
      <nav
        class="flex justify-end gap-4 text-[0.95rem] max-mobile:flex-wrap max-mobile:justify-start"
      >
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/tags">Tags</a>
      </nav>
    </header>
    <main class:list={mainClasses}>
      <slot />
    </main>
    <footer
      class="mx-auto mb-10 max-w-[76ch] px-6 text-center text-[0.85rem] text-muted"
    >
      <span>Notes for thinking.</span>
    </footer>
  </body>
</html>
