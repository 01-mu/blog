---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";

const homeLayoutClass =
  "grid grid-cols-[minmax(0,1fr)_minmax(0,82ch)_220px_minmax(0,1fr)] items-start gap-10 max-tablet:grid-cols-[minmax(0,1fr)] max-mobile:flex max-mobile:flex-col";
const homeContentClass =
  "col-[2] min-w-0 bg-paper px-11 pt-10 pb-[2.6rem] max-tablet:col-auto max-tablet:w-full max-mobile:order-1 max-mobile:px-6 max-mobile:pt-8 max-mobile:pb-9";
const pageTitleClass = "mt-0";
---

<BaseLayout title="About" mainClass="main--home">
  <div class={homeLayoutClass}>
    <section class={homeContentClass}>
      <h1 class={pageTitleClass}>About</h1>

      <p>
        <strong>Hello! Developers</strong><br />
        I write and build under the name <strong>Masato</strong>.<br />
        I’m a software engineer based in Japan.<br />
      </p>

      <p>
        I have been involved in <strong>upstream design and development</strong>, mainly working on logistics systems.<br />
        My experience includes .NET, Vue, and Python, with a strong focus on <strong>backend and database design</strong>.<br />
        In my personal projects, I prefer using <strong>TypeScript</strong>.<br />
        I aim to build systems that are <strong>simple, clear, and efficient</strong> — I believe simplicity naturally leads to better performance and maintainability.
      </p>

      <p>
        Outside of coding, I enjoy <strong>manga</strong> and read Weekly Shonen Jump regularly.<br />
        I also watch films with English subtitles for learning, and I’ve been going to the gym consistently since last November.
      </p>

      <p>
        I’m currently aiming to <strong>work abroad</strong> and build <strong>simple, effective systems</strong> with others.
      </p>
    </section>
    <Sidebar />
  </div>
</BaseLayout>
